@typeparam TArgs
@typeparam TData
@implements IDisposable

@if (_state.IsSuccess && _state.CurrentData is { } data)
{
    @Content(data)
}
else if (_state.IsFailure && _state.Error is { } error)
{
    @Failure?.Invoke(error)
